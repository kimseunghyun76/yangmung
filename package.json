{
  "name": "yangmung",
  "private": true,
  "version": "0.1.0",
  "description": "성인용 발달식 일본어 학습 — 여행 미션 + 가나 자동화 + Recovery + SRS",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "assets:generate": "node scripts/generate-scene-assets.mjs",
    "assets:variants": "tsx scripts/generate-session-variants.mjs",
    "assets:vocab": "node scripts/generate-vocab-word-assets.mjs && node scripts/optimize-vocab-assets.mjs --remove-png",
    "assets:signs": "tsx scripts/generate-sign-art-assets.ts && node scripts/optimize-vocab-assets.mjs --remove-png",
    "assets:signs:rendered": "node scripts/render-sign-art-from-templates.mjs",
    "assets:vocab:optimize": "node scripts/optimize-vocab-assets.mjs --remove-png",
    "assets:gacha": "tsx scripts/generate-gacha-item-assets.mjs && node scripts/optimize-gacha-assets.mjs --remove-png && node scripts/zoom-gacha-item-assets.mjs",
    "assets:gacha:optimize": "node scripts/optimize-gacha-assets.mjs --remove-png",
    "audio": "tsx scripts/generate-audio.mjs",
    "audio:dry": "tsx scripts/generate-audio.mjs --dry",
    "typecheck": "tsc --noEmit",
    "lint:content": "tsx src/content/validate.ts",
    "report:n5": "tsx src/content/n5.report.ts",
    "lint:sentences": "tsx src/content/sceneSentences.validate.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.19",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^6.0.5",
    "vitest": "^4.1.10"
  }
}
