{
  "name": "yangmung",
  "private": true,
  "version": "0.1.0",
  "description": "성인용 발달식 일본어 학습 — 여행 미션 + 가나 자동화 + Recovery + SRS",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
