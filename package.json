{
  "name": "yangmung",
  "private": true,
  "version": "0.1.0",
  "description": "성인용 발달식 일본어 학습 — 여행 미션 + 가나 자동화 + Recovery + SRS",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "assets:generate": "node scripts/generate-scene-assets.mjs",
    "assets:variants": "tsx scripts/generate-session-variants.mjs",
    "assets:vocab": "node scripts/generate-vocab-word-assets.mjs && node scripts/optimize-vocab-assets.mjs --remove-png",
    "assets:signs": "tsx scripts/generate-sign-art-assets.ts && node scripts/optimize-vocab-assets.mjs --remove-png",
    "assets:vocab:optimize": "node scripts/optimize-vocab-assets.mjs --remove-png",
    "assets:gacha:optimize": "node scripts/optimize-gacha-assets.mjs --remove-png",
    "audio": "tsx scripts/generate-audio.mjs",
    "audio:dry": "tsx scripts/generate-audio.mjs --dry",
    "typecheck": "tsc --noEmit",
    "lint:content": "tsx src/content/validate.ts",
    "lint:sentences": "tsx src/content/sceneSentences.validate.ts",
    "test:content": "tsx src/content/validate.test.ts",
    "test:adaptive": "tsx src/learn/adaptive.test.ts",
    "test:progress": "tsx src/learn/progress.test.ts",
    "test:cards": "tsx src/learn/cards.test.ts",
    "test:unlocks": "tsx src/learn/unlocks.test.ts",
    "test:progression": "tsx src/learn/progression.test.ts",
    "test:missionmix": "tsx src/learn/missionMix.test.ts",
    "test": "npm run test:content && npm run test:adaptive && npm run test:progress && npm run test:cards && npm run test:unlocks && npm run test:progression && npm run test:missionmix"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
